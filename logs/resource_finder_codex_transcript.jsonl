{"type":"item.started","item":{"id":"item_46","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - <<'PY'\nfrom pathlib import Path\nimport json\nimport pandas as pd\nfrom sklearn.datasets import load_wine, load_breast_cancer, load_iris\nfrom ucimlrepo import fetch_ucirepo\n\nroot = Path('datasets')\nroot.mkdir(exist_ok=True)\n\nsummary = []\n\ndef save_sklearn(name, bunch, target_name='target'):\n    d = root / name\n    d.mkdir(exist_ok=True)\n    df = pd.DataFrame(bunch.data, columns=bunch.feature_names)\n    df[target_name] = bunch.target\n    csv_path = d / f'{name}.csv'\n    df.to_csv(csv_path, index=False)\n    with open(d / 'samples.json', 'w') as f:\n        json.dump(df.head(10).to_dict(orient='records'), f, indent=2)\n    summary.append({'name': name, 'rows': len(df), 'cols': len(df.columns)-1, 'task': 'classification', 'path': str(csv_path)})\n\nsave_sklearn('sklearn_wine', load_wine())\nsave_sklearn('sklearn_breast_cancer', load_breast_cancer())\nsave_sklearn('sklearn_iris', load_iris())\n\nfor repo_id, name, task in [(42, 'uci_glass_identification', 'classification'), (151, 'uci_connectionist_bench_sonar', 'classification'), (186, 'uci_wine_quality_red', 'regression')]:\n    ds = fetch_ucirepo(id=repo_id)\n    d = root / name\n    d.mkdir(exist_ok=True)\n    df = pd.concat([ds.data.features, ds.data.targets], axis=1)\n    csv_path = d / f'{name}.csv'\n    df.to_csv(csv_path, index=False)\n    with open(d / 'samples.json', 'w') as f:\n        json.dump(df.head(10).to_dict(orient='records'), f, indent=2, default=str)\n    summary.append({'name': name, 'rows': len(df), 'cols': len(df.columns)-1, 'task': task, 'path': str(csv_path)})\n\nfor item in summary:\n    print(item)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
